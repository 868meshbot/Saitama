# PlatformIO build artefacts
.pio/

# macOS
.DS_Store
**/.DS_Store

# Editor
.vscode/
*.swp
*.swo

# Secrets / credentials
*.pem
*.key
secrets.*

# Firmware binaries (built by CI)
firmware/*
*.bin
*.elf
*.hex
*.map
# Allow named release artifacts (saitama-<device>-<version>[.bin|-merged.bin])
!firmware/saitama-*.bin

# Python
__pycache__/
*.pyc
*.pyo

# SD card tile cache (local only)
map-tiles/
tiles/
